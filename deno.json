{
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@1.0.1",
    "@cliffy/command": "jsr:@cliffy/command@1.0.1",
    "@cliffy/prompt": "jsr:@cliffy/prompt@1.0.1",
    "@cliffy/table": "jsr:@cliffy/table@1.0.1"
